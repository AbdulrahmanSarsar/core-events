# Normalize line endings for source files.
*.php   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.txt   text eol=lf
*.pot   text eol=lf
*.md    text eol=lf

# Files excluded from `git archive` exports (not shipped to buyers).
.gitignore              export-ignore
.gitattributes          export-ignore
.claude/                export-ignore
CLAUDE.md               export-ignore
TESTING.md              export-ignore
build_user_guide.py     export-ignore
/dist/                  export-ignore
